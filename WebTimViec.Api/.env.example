# HelperHub Backend - Environment Variables Example
# Copy this file to .env and replace with your REAL values.

# JWT Security (Must be 512 bits for HS512)
AppSettings__Token=CHANGE_ME_TO_A_LONG_SECURE_KEY_RANDOM_STRING_HERE

# SMTP Credentials (Gmail)
SmtpSettings__User=your-email@gmail.com
SmtpSettings__Password=your-app-password

# VNPay Security (Sandbox)
VnPaySettings__TmnCode=CHANGE_ME
VnPaySettings__HashSecret=CHANGE_ME

# Database connection details
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=webtimviec;Username=postgres;Password=password

# Allowed Origins (CORS)
AllowedOrigins=http://localhost:5173,https://your-ngrok-domain.ngrok-free.app
